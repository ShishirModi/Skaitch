# Secure password for accessing Admin Mode in the Streamlit app
ADMIN_PASSWORD=your_secure_password_here

# Optional Direct URL for DeepFaceDrawing weights (e.g. Google Drive or S3 link)
DFD_WEIGHTS_DIRECT_URL=

# Directory to download and load all ML model weights (SDXL, ControlNet, CodeFormer).
# If left blank, it defaults to a local './models' directory inside the repository.
# Example of the legacy AWS DLAMI NVMe attached storage path:
# SKAITCH_MODEL_DIR=/opt/dlami/nvme/models
SKAITCH_MODEL_DIR=/opt/dlami/nvme/models
